     <property name="readOnly">
      <bool>true</bool>
     </property>
     <property name="plainText">
      <string>ServiceCenter Manager is a software solution designed to streamline the workflow of repair service centers. 
The system provides tools for managing customer orders, tracking repair progress, assigning technicians, generating statistics, and maintaining financial records.
Its goal is to simplify daily operations, reduce manual work, and improve service quality.


Developed by
Arsenii Luchaninov</string>
     </property>
    </widget>
   </item>
  </layout>
